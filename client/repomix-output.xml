<file path="src/components/items/AddProductForm.jsx">
"use client";

import { useState } from "react";
import { useRouter } from "next/navigation";
import { toast } from "react-toastify";
import { motion, AnimatePresence } from "framer-motion";
import Image from "next/image";
import { FaTrashAlt } from "react-icons/fa";

import { createProduct } from "@/services/productService";
import { uploadImage } from "@/utils/uploadImage";
import ImageUploader from "@/components/shared/ImageUploader"; // Adjust this import path if needed

export default function AddProductForm() {
  const router = useRouter();

  // State shared with the ImageUploader
  const [file, setFile] = useState(null);
  const [preview, setPreview] = useState(null);
  const [uploading, setUploading] = useState(false);

  // Controlled Form State
  const [formData, setFormData] = useState({
    title: "",
    category: "Laptop",
    price: "",
    description: "",
  });

  // Track changes on text, select, and textarea inputs (Clean JS version)
  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData((prev) => ({ ...prev, [name]: value }));
  };

  const removeImage = () => {
    setPreview(null);
    setFile(null);
  };

  const handleSubmit = async (e) => {
    e.preventDefault();

    if (!file) {
      return toast.error("Please select or drop an image first.");
    }

    try {
      setUploading(true);

      // 1. Upload the selected file to Cloudinary
      const imageUrl = await uploadImage(file);

      // 2. Format product payload directly from your React state
      const product = {
        title: formData.title,
        category: formData.category,
        price: Number(formData.price),
        image: imageUrl,
        description: formData.description,
        rating: 5,
      };

      // 3. Save to database
      await createProduct(product);
      toast.success("Product Added Successfully!");

      // 4. Reset form state on success
      setPreview(null);
      setFile(null);
      setFormData({
        title: "",
        category: "Laptop",
        price: "",
        description: "",
      });

      router.push("/items/manage");
    } catch (error) {
      console.error("Save error:", error);
      toast.error("Failed to upload product.");
    } finally {
      setUploading(false);
    }
  };

  return (
    <main className="page-section">
      <div className="mx-auto max-w-7xl">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5 }}
          className="w-full max-w-6xl rounded-3xl border border-slate-200 bg-white p-6 md:p-10 shadow-xl"
        >
          {/* Header */}
          <div className="mb-10 border-b border-slate-200 pb-6">
            <h2 className="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
              Add New Product
            </h2>
            <p className="mt-2 text-sm text-slate-500">
              Publish an item into the marketplace with modern asset styling.
            </p>
          </div>

          {/* Layout: Reversed to 5 columns preview/upload / 7 columns form */}
          <div className="grid gap-8 lg:grid-cols-12 items-start">
            {/* Left Side: Upload Image & Preview (5 Columns) */}
            <div className="lg:col-span-5 space-y-6 lg:sticky lg:top-8">
              {/* Image Uploader */}
              <div>
                <label className="mb-2 block text-sm font-semibold text-slate-700">
                  Upload Image
                </label>
                <div className="rounded-2xl border-2 border-dashed border-cyan-300 bg-cyan-50 p-4 hover:bg-cyan-100 transition-colors">
                  <ImageUploader
                    preview={preview}
                    setPreview={setPreview}
                    setFile={setFile}
                  />
                </div>
              </div>

              {/* Preview Card */}
              <div className="space-y-3">
                <h3 className="text-sm font-semibold tracking-wider text-slate-400 uppercase">
                  Live Preview
                </h3>

                <div className="group relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-4 shadow-xl transition-all duration-300">
                  <div className="relative aspect-video w-full overflow-hidden rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center">
                    {preview ? (
                      <>
                        <Image
                          src={preview}
                          alt="Product Live View"
                          fill
                          className="object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                        <button
                          type="button"
                          onClick={removeImage}
                          className="absolute right-3 top-3 rounded-full bg-rose-500 p-2.5 text-white hover:bg-rose-600 transition shadow-lg z-10"
                          title="Remove Image"
                        >
                          <FaTrashAlt size={14} />
                        </button>
                      </>
                    ) : (
                      <div className="text-center p-6 space-y-2">
                        <div className="mx-auto w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-400">
                          🖼️
                        </div>
                        <p className="text-xs text-slate-400 font-medium">
                          No cover image uploaded yet
                        </p>
                      </div>
                    )}
                  </div>

                  {/* Live Card Metadata */}
                  <div className="mt-5 space-y-2">
                    <span className="inline-block text-xs font-semibold tracking-wide text-cyan-600 uppercase">
                      {formData.category || "Laptop"}
                    </span>

                    <h4 className="line-clamp-1 text-lg font-bold text-slate-900 transition-colors">
                      {formData.title || "MacBook Air M4"}
                    </h4>

                    <div className="flex items-center gap-1 text-amber-400 text-sm">
                      {"⭐⭐⭐⭐⭐"}
                    </div>

                    <span className="block text-xl font-bold text-slate-900">
                      {formData.price
                        ? `$${Number(formData.price).toLocaleString()}`
                        : "$1299"}
                    </span>

                    <p className="line-clamp-3 text-sm leading-relaxed text-slate-500 min-h-[60px] pt-1">
                      {formData.description || "Description"}
                    </p>
                  </div>
                </div>
              </div>
            </div>

            {/* Right Side: Product Form (7 Columns) */}
            <form onSubmit={handleSubmit} className="space-y-6 lg:col-span-7">
              <div className="grid gap-6 sm:grid-cols-2">
                <div className="sm:col-span-2">
                  <label className="mb-2 block text-sm font-semibold text-slate-700">
                    Product Title
                  </label>
                  <input
                    name="title"
                    required
                    value={formData.title}
                    onChange={handleInputChange}
                    placeholder="e.g. MacBook Air M4 Pro"
                    className="w-full rounded-xl border border-slate-300 bg-white p-4 text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-cyan-500"
                  />
                </div>

                <div>
                  <label className="mb-2 block text-sm font-semibold text-slate-700">
                    Category
                  </label>
                  <select
                    name="category"
                    value={formData.category}
                    onChange={handleInputChange}
                    className="w-full rounded-xl border border-slate-300 bg-white p-4 text-slate-800 outline-none transition focus:border-cyan-500"
                  >
                    <option value="Laptop">Laptop</option>
                    <option value="Phone">Phone</option>
                    <option value="Tablet">Tablet</option>
                    <option value="Watch">Watch</option>
                    <option value="Headphone">Headphone</option>
                  </select>
                </div>

                <div>
                  <label className="mb-2 block text-sm font-semibold text-slate-700">
                    Price ($)
                  </label>
                  <input
                    name="price"
                    type="number"
                    required
                    value={formData.price}
                    onChange={handleInputChange}
                    placeholder="999"
                    className="w-full rounded-xl border border-slate-300 bg-white p-4 text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-cyan-500"
                  />
                </div>
              </div>

              <div>
                <label className="mb-2 block text-sm font-semibold text-slate-700">
                  Description
                </label>
                <textarea
                  name="description"
                  rows={6}
                  value={formData.description}
                  onChange={handleInputChange}
                  placeholder="Describe your flagship specs..."
                  className="w-full rounded-xl border border-slate-300 bg-white p-4 text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-cyan-500 resize-none"
                />
              </div>

              {/* Progress Bar */}
              <AnimatePresence>
                {uploading && (
                  <motion.div
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: "auto" }}
                    exit={{ opacity: 0, height: 0 }}
                    className="space-y-2 overflow-hidden"
                  >
                    <div className="flex justify-between text-xs font-semibold text-cyan-600">
                      <span>Uploading directly to Cloudinary...</span>
                      <span className="animate-pulse">Active</span>
                    </div>
                    <div className="h-2 w-full overflow-hidden rounded-full bg-slate-100">
                      <motion.div
                        initial={{ x: "-100%" }}
                        animate={{ x: "0%" }}
                        transition={{
                          repeat: Infinity,
                          duration: 1.5,
                          ease: "linear",
                        }}
                        className="h-full w-full bg-gradient-to-r from-cyan-500 to-blue-600"
                      />
                    </div>
                  </motion.div>
                )}
              </AnimatePresence>

              <button
                type="submit"
                disabled={uploading}
                className="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 py-4 font-bold text-white shadow-lg hover:scale-[1.02] transition disabled:cursor-not-allowed disabled:opacity-50 flex items-center justify-center"
              >
                {uploading ? (
                  <span className="flex items-center gap-2">
                    <svg
                      className="h-5 w-5 animate-spin text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                    >
                      <circle
                        className="opacity-25"
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        strokeWidth="4"
                      />
                      <path
                        className="opacity-75"
                        fill="currentColor"
                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                      />
                    </svg>
                    Processing Assets...
                  </span>
                ) : (
                  "Add Product"
                )}
              </button>
            </form>
          </div>
        </motion.div>
      </div>
    </main>
  );
}
